# PMB 環境變數範本 — 複製成 .env 後填入真實值。.env 已被 .gitignore 排除,絕不入庫。

# --- Phase 0: 資料層 ---
# FRED API key (免費申請:https://fred.stlouisfed.org/docs/api/api_key.html)
FRED_API_KEY=

# --- 研究來源 ---
# RESEARCH_SOURCE=local             # local(預設,本機 headless claude -p)| cloud(等雲端 routine)
# LOCAL_RESEARCH_FALLBACK=true      # cloud 模式逾時是否本機補跑
# RESEARCH_CLAUDE_MODEL=claude-sonnet-5  # headless 研究模型;額度餘裕優先,要高品質可 claude-opus-4-8

# --- Phase 1: 研究 API 路徑(選配,只給自動化測試;正式研究走 headless Claude Code 免 key) ---
# ANTHROPIC_API_KEY=

# --- Phase 4: 影片字幕字型 ---
# 雲端 Linux 用預設 Noto Sans CJK TC(setup 裝 fonts-noto-cjk);本機 macOS 設下行
# VIDEO_FONT=PingFang TC

# --- Phase 4: 配音(可選) ---
# TTS_VOICE=zh-TW-HsiaoChenNeural   # 換 zh-TW-HsiaoYuNeural 較暖 / zh-TW-YunJheNeural 男聲
# TTS_RATE=+40%
# TTS_PITCH=+0Hz                    # 如 +5Hz 可降低單調感,幅度別超過 ±15Hz

# --- Phase 4: BGM(可選) ---
# BGM_ENABLE=true                   # false 關閉背景音樂
# BGM_DIR=assets/bgm                # 放自有 royalty-free 音檔按日輪播;空則程序化合成低調 pad
# BGM_GAIN_DB=-14                   # BGM 音量(dB;-14≈人聲下方 17–18dB,嫌吵 -18、想明顯 -11)

# --- Phase 5: 發布 (之後階段才需要;建議只在受信任機器/人工放行時用,別放雲端 routine) ---
# YOUTUBE_CLIENT_ID=
# YOUTUBE_CLIENT_SECRET=
# YOUTUBE_REFRESH_TOKEN=
# YOUTUBE_PLAYLIST_ID=              # 每日影片自動加入的播放清單(需 auth-youtube 的 youtube scope)
# YOUTUBE_DISCLOSE_SYNTHETIC=true   # 上傳時自動揭露合成內容(TTS);頻道政策預設開
